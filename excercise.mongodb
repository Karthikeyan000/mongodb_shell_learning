// Insert a Single Document
// Use insertOne() to insert a single document into a collection. Within insertOne(), include

db.grades.insertOne({
  student_id: 654321,
  products: [
    {
      type: "exam",
      score: 90,
    },
    {
      type: "homework",
      score: 59,
    },
    {
      type: "quiz",
      score: 75,
    },
    {
      type: "homework",
      score: 88,
    },
  ],
  class_id: 550,
})

// Insert Multiple Documents
// Use insertMany() to insert multiple documents at once. Within insertMany(), include the documents within an array. Each document should be separated by a comma. Here's an example:

db.grades.insertMany([
  {
    student_id: 546789,
    products: [
      {
        type: "quiz",
        score: 50,
      },
      {
        type: "homework",
        score: 70,
      },
      {
        type: "quiz",
        score: 66,
      },
      {
        type: "exam",
        score: 70,
      },
    ],
    class_id: 551,
  },
  {
    student_id: 777777,
    products: [
      {
        type: "exam",
        score: 83,
      },
      {
        type: "quiz",
        score: 59,
      },
      {
        type: "quiz",
        score: 72,
      },
      {
        type: "quiz",
        score: 67,
      },
    ],
    class_id: 550,
  },
  {
    student_id: 223344,
    products: [
      {
        type: "exam",
        score: 45,
      },
      {
        type: "homework",
        score: 39,
      },
      {
        type: "quiz",
        score: 40,
      },
      {
        type: "homework",
        score: 88,
      },
    ],
    class_id: 551,
  },
])

// Find Documents
// Use find() to query for documents in a collection. Within find(), include a query document

db.grades.find({studeut_id: 547699})
// output
[
  {
    _id: ObjectId('699ab3920da871b0f17236a2'),
    studeut_id: 547699,
    scores: []
  },
  {
    _id: ObjectId('699ab4270da871b0f17236a3'),
    studeut_id: 547699,
    scores: [ { type: 'quiz', score: 90 }, { type: 'homework', score: 70 } ]
  },
  {
    _id: ObjectId('699ab4c30da871b0f17236a4'),
    studeut_id: 547699,
    scores: [ { type: 'quiz', score: 90 }, { type: 'homework', score: 70 } ]
  }
]

// find all documents where the student_id is either 547699 or 534699. Use the $in operator to specify multiple values for a field. Here's an example:

db.grades.find({studeut_id: {$in:[547699,534699]}})
// output
[
  {
    _id: ObjectId('699ab3920da871b0f17236a2'),
    studeut_id: 547699,
    scores: []
  },
  {
    _id: ObjectId('699ab4270da871b0f17236a3'),
    studeut_id: 547699,
    scores: [ { type: 'quiz', score: 90 }, { type: 'homework', score: 70 } ]
  },
  {
    _id: ObjectId('699ab4c30da871b0f17236a4'),
    studeut_id: 547699,
    scores: [ { type: 'quiz', score: 90 }, { type: 'homework', score: 70 } ]
  },
  {
    _id: ObjectId('699ab4c30da871b0f17236a6'),
    studeut_id: 534699,
    scores: [ { type: 'quiz', score: 80 }, { type: 'homework', score: 100 } ]
  }
]

// find all documents where the student_id is greater than 547698. Use the $gt operator to specify a value that a field must be greater than. Here's an example:

db.grades.find({studeut_id: {$gt:547698}})
// output
[
  {
    _id: ObjectId('699ab3920da871b0f17236a2'),
    studeut_id: 547699,
    scores: []
  },
  {
    _id: ObjectId('699ab4270da871b0f17236a3'),
    studeut_id: 547699,
    scores: [ { type: 'quiz', score: 90 }, { type: 'homework', score: 70 } ]
  },
  {
    _id: ObjectId('699ab4c30da871b0f17236a4'),
    studeut_id: 547699,
    scores: [ { type: 'quiz', score: 90 }, { type: 'homework', score: 70 } ]
  }
]

// find all documents where the student_id is less than or equal to 547698. Use the $lte operator to specify a value that a field must be less than or equal to. Here's an example:

